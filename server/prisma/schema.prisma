datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id               String     @id @default(cuid())
  name             String?
  age              String?    @default("18")
  gender           Gender?    @default(MALE)
  email            String
  emailVerified    Boolean    @default(false)
  image            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  country          String?    @default("dz")
  sessions         Session[]
  accounts         Account[]
  settings         Settings[]
  tasks            Tasks[]
  goals            Goals[]
  sentRequests     Friends[]  @relation("SentRequests")
  receivedRequests Friends[]  @relation("ReceivedRequests")
  notes            Notes[]
  categories       Category[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Friends {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  isAccepted Boolean  @default(false)
  senderId   String
  sender     User     @relation("SentRequests", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Notes {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("notes")
}

model Tasks {
  id        String   @id @default(cuid())
  name      String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  goalsId   String?
  goals     Goals?   @relation(fields: [goalsId], references: [id])

  @@map("tasks")
}

enum Priority {
  GOATED
  MAJOR
  VIBING
  CASUAL
  TRASH
}

model Goals {
  id         String    @id @default(cuid())
  name       String
  createdAt  DateTime  @default(now())
  endDate    DateTime?
  priority   Priority  @default(VIBING)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  categoryId String
  categories Category  @relation(fields: [categoryId], references: [id])
  tasks      Tasks[]

  @@map("goals")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  goals     Goals[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("categories")
}

enum SocialPlatform {
  DISCORD
  GITHUB
  INSTAGRAM
  X
  WHATSAPP
  YOUTUBE
  KICK
  TIKTOK
  TWITCH
  FACEBOOK
  MESSANGER
  TELEGRAM
  PINTEREST
}

model Socials {
  id         String         @id @default(cuid())
  name       SocialPlatform
  settingsId String
  settings   Settings       @relation(fields: [settingsId], references: [id])

  @@unique([settingsId, name])
  @@map("socials")
}

model Choices {
  id        String   @id @default(cuid())
  name      String
  Image     String   @default("/images/default_choice.jpg")
  createdAt DateTime @default(now())
}

model Settings {
  id      String    @id @default(cuid())
  userId  String    @unique
  theme   String    @default("default")
  mode    String    @default("dark")
  user    User      @relation(fields: [userId], references: [id])
  socials Socials[]

  @@map("settings")
}
